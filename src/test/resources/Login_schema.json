{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "statusCode": {
      "type": "integer"
    },
    "message": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "integer"
        },
        "email": {
          "type": "string"
        },
        "firstName": {
          "type": "string"
        },
        "jwtToken": {
          "type": ["string","null"]
        }
      },
      "required": ["userId", "email", "firstName"]
    }
  },
  "required": ["statusCode", "message", "data"]
}